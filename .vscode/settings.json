{
    "chat.disableAIFeatures": false,
    "mcp": {
        "servers": {
            "playwright-mcp": {
                "command": "npx",
                "args": [
                    "-y",
                    "@playwright/mcp"
                ],
                "env": {}
            },
            "github-mcp": {
                "command": "docker",
                "args": [
                    "run",
                    "-i",
                    "--rm",
                    "-e",
                    "GITHUB_PERSONAL_ACCESS_TOKEN",
                    "ghcr.io/github/github-mcp-server"
                ],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN"
                }
            }
        }
    }
}
